{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "LocalScribe",
  "version": "1.0.0",
  "identifier": "ai.swarmpath.localscribe",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:11517",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "LocalScribe",
        "width": 1100,
        "height": 760,
        "minWidth": 880,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "Offline audio transcription",
    "longDescription": "LocalScribe — completely offline audio transcription tool powered by Whisper, with optional LLM-assisted correction."
  },
  "plugins": {
    "shell": {
      "open": false
    }
  }
}
