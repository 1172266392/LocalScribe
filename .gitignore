# =============================================================================
# LocalScribe · .gitignore
# =============================================================================
# 哲学:仓库只放"源码 + 配置 + 文档",不放"产物 + 用户数据 + 凭据 + 大文件"。
# Lock 文件保留(pnpm-lock.yaml / Cargo.lock)用于可重现构建。
# =============================================================================

# ---- 构建产物 ----
node_modules/
dist/
src-tauri/target/
src-tauri/gen/schemas/
.venv/
venv/
env/
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
*.egg
build/
develop-eggs/
.eggs/

# ---- 转译/临时文件 ----
*.tsbuildinfo
.cache/
.parcel-cache/
.next/
.turbo/

# ---- 日志 ----
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# =============================================================================
# 凭据 / 密钥 / 个人配置(必须忽略,不能误传)
# =============================================================================
.env
.env.local
.env.*.local
.dev-secrets.json
secrets.json
*.pem
*.key
*.crt
.vault-secrets.yaml

# =============================================================================
# 用户数据(每个用户本机的转录结果 / 文章库 / 测试音频)
# =============================================================================
# 转录结果(用户本地产出,不应进仓库)
transcripts/

# 文章库(用户本地保存的内容,不应进仓库)
articles/

# Whisper 模型(1.5 GB,通过 install.sh 下载或单独下载放进 models/)
models/

# 测试 / 演示音频文件(大、可能含个人内容)
*.m4a
*.mp3
*.wav
*.ogg
*.flac
*.aac
*.opus
*.mp4
*.mov
*.mkv
*.webm

# 备份文件(我们的清理脚本产生的)
*.bak
*.bak2
*.bak3
*.bak.*

# =============================================================================
# OS / IDE / Editor
# =============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

.vscode/
!.vscode/extensions.json
!.vscode/settings.recommended.json
.idea/
*.swp
*.swo
*~
.vim/
.project
.classpath
.settings/

# Claude Code session state
.claude/

# =============================================================================
# Tauri / Rust 特定
# =============================================================================
src-tauri/WixTools/
*.dSYM/

# =============================================================================
# 个人 / 状态文档(可选,看你想不想公开)
# =============================================================================
# 这是开发当晚我留的状态报告 — 公开仓库可不放
MORNING_REPORT.md

# =============================================================================
# 显式保留(下面这些通常被工具默认忽略,这里强制保留)
# =============================================================================
!.gitignore
!.gitattributes
!src-tauri/icons/

# Lock 文件保留(可重现构建)
!pnpm-lock.yaml
!src-tauri/Cargo.lock
